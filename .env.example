# Copy to .env and fill in real values.

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
WA_PHONE_NUMBER_ID=1234567890
WA_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx
WA_VERIFY_TOKEN=my_super_secret_verify_token_2024

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/ataljanseva?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10

# ── Redis (local) ─────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Worker pool ───────────────────────────────────────────────────────────────
# 50 workers handles ~1000 concurrent conversations comfortably.
# Increase if DB/WA API latency is high (latency × target_rps = workers_needed)
WORKER_COUNT=50
QUEUE_DEPTH=2000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ENV=development   # set to "production" for JSON logs
