# Copy to .env and fill in real values before running locally.
# Never commit .env to source control.

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
# Found in Meta Developer Console → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=1234567890

# Permanent system-user access token (or temporary token for dev)
WA_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx

# The arbitrary string you enter when configuring the webhook in Meta dashboard
WA_VERIFY_TOKEN=my_super_secret_verify_token_2024

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
